<!--
  Honeypot Deployer - Custom Wazuh Alert Rules

  Install to: /var/ossec/etc/rules/honeypot_rules.xml

  Rule ID range: 100500 - 100599 (reserved for honeypot)

  Detection Layers:
    Layer 1 (100500-100509): File Access Detection (FIM-based)
    Layer 2 (100510-100519): Process & Command Auditing
    Layer 3 (100520-100529): Network Exfiltration Detection
    Layer 4 (100530-100539): On-Chain Transaction Monitoring
    Meta   (100540-100549): Correlation Rules
-->

<group name="honeypot,crypto_wallet">

  <!-- ============================================ -->
  <!-- LAYER 1: File Access Detection (FIM-based)   -->
  <!-- ============================================ -->

  <!-- Base rule: Any FIM event on honeypot wallet files -->
  <rule id="100500" level="0">
    <if_group>syscheck</if_group>
    <field name="syscheck.path">.bitcoin/wallets|.ethereum/keystore|.config/solana|.electrum/wallets|.config/Exodus|seed-backup|crypto-recovery|wallet-backup|.seed_phrase|.cardano/payment|xrp-wallet</field>
    <description>HONEYPOT: FIM event on crypto wallet honeypot file</description>
    <group>honeypot,fim</group>
  </rule>

  <!-- Honeypot wallet file accessed (read) -->
  <rule id="100501" level="12">
    <if_sid>100500</if_sid>
    <field name="syscheck.audit.process.name">\S+</field>
    <description>HONEYPOT ALERT: Crypto wallet honeypot file accessed by process $(syscheck.audit.process.name) [User: $(syscheck.audit.user.name)]</description>
    <mitre>
      <id>T1005</id>
    </mitre>
    <group>honeypot,wallet_access,high</group>
    <options>alert_by_email</options>
  </rule>

  <!-- Honeypot wallet file modified -->
  <rule id="100502" level="14">
    <if_sid>100500</if_sid>
    <field name="syscheck.event">modified</field>
    <description>HONEYPOT CRITICAL: Crypto wallet honeypot file MODIFIED by $(syscheck.audit.process.name) - possible key extraction</description>
    <mitre>
      <id>T1005</id>
    </mitre>
    <group>honeypot,wallet_modified,critical</group>
    <options>alert_by_email</options>
  </rule>

  <!-- Honeypot wallet file deleted -->
  <rule id="100503" level="14">
    <if_sid>100500</if_sid>
    <field name="syscheck.event">deleted</field>
    <description>HONEYPOT CRITICAL: Crypto wallet honeypot file DELETED - attacker covering tracks</description>
    <mitre>
      <id>T1070</id>
    </mitre>
    <group>honeypot,wallet_deleted,critical</group>
    <options>alert_by_email</options>
  </rule>

  <!-- Seed phrase file accessed -->
  <rule id="100504" level="13">
    <if_sid>100500</if_sid>
    <field name="syscheck.path">seed-backup|seed_phrase|crypto-recovery|wallet-backup</field>
    <description>HONEYPOT ALERT: Seed phrase honeypot file accessed by $(syscheck.audit.process.name)</description>
    <mitre>
      <id>T1555</id>
    </mitre>
    <group>honeypot,seed_access,critical</group>
    <options>alert_by_email</options>
  </rule>

  <!-- Browser extension wallet data accessed -->
  <rule id="100505" level="13">
    <if_sid>100500</if_sid>
    <field name="syscheck.path">nkbihfbeogaeaoehlefnkodbefgpgknn|bfnaelmomeimhlpmgjnjophhpkkoljpa|hnfanknocfeofbddgcijnmhnfnkdnaad</field>
    <description>HONEYPOT ALERT: Browser wallet extension honeypot data accessed</description>
    <mitre>
      <id>T1555.003</id>
    </mitre>
    <group>honeypot,browser_wallet,critical</group>
    <options>alert_by_email</options>
  </rule>

  <!-- Electrum wallet file accessed -->
  <rule id="100506" level="12">
    <if_sid>100500</if_sid>
    <field name="syscheck.path">.electrum/wallets</field>
    <description>HONEYPOT ALERT: Electrum wallet honeypot file accessed by $(syscheck.audit.process.name)</description>
    <mitre>
      <id>T1005</id>
    </mitre>
    <group>honeypot,electrum_access,high</group>
    <options>alert_by_email</options>
  </rule>

  <!-- Exodus wallet data accessed -->
  <rule id="100507" level="12">
    <if_sid>100500</if_sid>
    <field name="syscheck.path">.config/Exodus</field>
    <description>HONEYPOT ALERT: Exodus wallet honeypot data accessed by $(syscheck.audit.process.name)</description>
    <mitre>
      <id>T1005</id>
    </mitre>
    <group>honeypot,exodus_access,high</group>
    <options>alert_by_email</options>
  </rule>

  <!-- ============================================ -->
  <!-- LAYER 2: Process & Command Auditing          -->
  <!-- ============================================ -->

  <!-- Audit rule triggered on honeypot crypto artifact -->
  <rule id="100510" level="10">
    <if_group>audit</if_group>
    <field name="audit.key">honeypot_btc_wallet|honeypot_eth_keystore|honeypot_sol_wallet|honeypot_seed_file|honeypot_electrum|honeypot_exodus|honeypot_ada_wallet|honeypot_xrp_wallet</field>
    <description>HONEYPOT: Audit rule triggered - process accessed honeypot crypto artifact [Key: $(audit.key)]</description>
    <mitre>
      <id>T1083</id>
    </mitre>
    <group>honeypot,audit,process_access</group>
  </rule>

  <!-- Rapid sequential access to multiple wallet paths = infostealer -->
  <rule id="100511" level="14" frequency="3" timeframe="30">
    <if_matched_sid>100510</if_matched_sid>
    <description>HONEYPOT CRITICAL: Rapid sequential access to multiple wallet honeypots - INFOSTEALER BEHAVIOR DETECTED</description>
    <mitre>
      <id>T1005</id>
      <id>T1083</id>
    </mitre>
    <group>honeypot,infostealer,critical</group>
    <options>alert_by_email</options>
  </rule>

  <!-- Suspicious process scanning for wallet paths -->
  <rule id="100512" level="11">
    <if_group>audit</if_group>
    <field name="audit.key">honeypot_</field>
    <field name="audit.exe">find|locate|ls|dir|Get-ChildItem</field>
    <description>HONEYPOT: Filesystem enumeration tool ($(audit.exe)) accessed honeypot wallet path</description>
    <mitre>
      <id>T1083</id>
    </mitre>
    <group>honeypot,enumeration,high</group>
  </rule>

  <!-- ============================================ -->
  <!-- LAYER 3: Network Exfiltration Detection      -->
  <!-- ============================================ -->

  <!-- Network-capable process accessed honeypot wallet artifact -->
  <rule id="100520" level="14">
    <if_sid>100510</if_sid>
    <field name="audit.exe">curl|wget|nc|ncat|scp|sftp|rsync|python|python3|ruby|perl|powershell|cmd.exe</field>
    <description>HONEYPOT CRITICAL: Potential exfiltration - network-capable process $(audit.exe) accessed honeypot wallet artifact</description>
    <mitre>
      <id>T1041</id>
    </mitre>
    <group>honeypot,exfiltration,critical</group>
    <options>alert_by_email</options>
  </rule>

  <!-- DNS query to known paste/upload/exfil sites after honeypot access -->
  <rule id="100521" level="12">
    <if_sid>100501</if_sid>
    <field name="dns.query">pastebin|transfer.sh|file.io|0x0.st|hastebin|ghostbin|telegram|discord\.com/api|webhook\.site</field>
    <description>HONEYPOT: DNS resolution to exfiltration-associated domain after wallet honeypot access</description>
    <mitre>
      <id>T1048</id>
    </mitre>
    <group>honeypot,exfiltration,dns</group>
  </rule>

  <!-- Archive utility used after honeypot file access -->
  <rule id="100522" level="13">
    <if_sid>100510</if_sid>
    <field name="audit.exe">zip|tar|gzip|7z|rar|Compress-Archive</field>
    <description>HONEYPOT: Archive utility $(audit.exe) used after accessing honeypot artifact - staging for exfiltration</description>
    <mitre>
      <id>T1560</id>
    </mitre>
    <group>honeypot,staging,high</group>
    <options>alert_by_email</options>
  </rule>

  <!-- ============================================ -->
  <!-- LAYER 4: On-Chain Transaction Monitoring     -->
  <!-- ============================================ -->

  <!-- Chain Monitor: any activity on honeypot address -->
  <rule id="100530" level="15">
    <decoded_as>json</decoded_as>
    <field name="source">chain-monitor</field>
    <field name="event_type">honeypot_chain_activity</field>
    <description>HONEYPOT CRITICAL: On-chain activity detected on honeypot $(chain) address $(address) - ATTACKER IS USING STOLEN KEYS</description>
    <mitre>
      <id>T1657</id>
    </mitre>
    <group>honeypot,chain_activity,critical</group>
    <options>alert_by_email</options>
  </rule>

  <!-- Chain Monitor: balance query on honeypot address -->
  <rule id="100531" level="13">
    <decoded_as>json</decoded_as>
    <field name="source">chain-monitor</field>
    <field name="activity_type">balance_query</field>
    <description>HONEYPOT: Balance query detected on honeypot $(chain) address - attacker is evaluating stolen wallet</description>
    <mitre>
      <id>T1657</id>
    </mitre>
    <group>honeypot,chain_activity,recon</group>
  </rule>

  <!-- Chain Monitor: outbound transfer attempt from honeypot address -->
  <rule id="100532" level="15">
    <decoded_as>json</decoded_as>
    <field name="source">chain-monitor</field>
    <field name="activity_type">outbound_transfer</field>
    <description>HONEYPOT CRITICAL: Outbound transfer attempt from honeypot $(chain) address - ACTIVE THEFT IN PROGRESS</description>
    <mitre>
      <id>T1657</id>
    </mitre>
    <group>honeypot,chain_activity,theft,critical</group>
    <options>alert_by_email</options>
  </rule>

  <!-- Chain Monitor: token approval on honeypot address (DeFi drainer) -->
  <rule id="100533" level="15">
    <decoded_as>json</decoded_as>
    <field name="source">chain-monitor</field>
    <field name="activity_type">token_approval</field>
    <description>HONEYPOT CRITICAL: Token approval detected on honeypot $(chain) address - DEFI DRAINER ATTACK</description>
    <mitre>
      <id>T1657</id>
    </mitre>
    <group>honeypot,chain_activity,drainer,critical</group>
    <options>alert_by_email</options>
  </rule>

  <!-- ============================================ -->
  <!-- META: Correlation Rules                      -->
  <!-- ============================================ -->

  <!-- File access followed by chain activity = confirmed compromise -->
  <rule id="100540" level="15" frequency="2" timeframe="86400">
    <if_matched_group>honeypot</if_matched_group>
    <same_field>honeypot</same_field>
    <description>HONEYPOT CRITICAL: Correlated attack chain detected - file access + on-chain activity within 24h. Full compromise confirmed.</description>
    <mitre>
      <id>T1005</id>
      <id>T1657</id>
    </mitre>
    <group>honeypot,correlated,critical</group>
    <options>alert_by_email</options>
  </rule>

  <!-- Multiple honeypot types triggered = sophisticated attack -->
  <rule id="100541" level="15" frequency="3" timeframe="300">
    <if_matched_group>honeypot</if_matched_group>
    <description>HONEYPOT CRITICAL: Multiple honeypot types triggered within 5 minutes - sophisticated or automated attack in progress</description>
    <mitre>
      <id>T1005</id>
      <id>T1083</id>
    </mitre>
    <group>honeypot,multi_trigger,critical</group>
    <options>alert_by_email</options>
  </rule>

</group>
