<group name="syscheck,crypto_honeypot,">
  <!-- Rule for Bitcoin wallet access -->
  <rule id="100500" level="12">
    <if_sid>550,554,553</if_sid>
    <field name="syscheck.path">\.bitcoin/wallet\.dat$|Bitcoin/wallet\.dat$</field>
    <description>Crypto Honeypot: Access or modification detected in Bitcoin wallet.dat</description>
    <mitre>
      <id>T1552.004</id>
    </mitre>
  </rule>

  <!-- Rule for Ethereum keystore access -->
  <rule id="100501" level="12">
    <if_sid>550,554,553</if_sid>
    <field name="syscheck.path">\.ethereum/keystore/UTC--|Ethereum/keystore/UTC--</field>
    <description>Crypto Honeypot: Access or modification detected in Ethereum keystore file</description>
    <mitre>
      <id>T1552.004</id>
    </mitre>
  </rule>

  <!-- Rule for Solana id.json access -->
  <rule id="100502" level="12">
    <if_sid>550,554,553</if_sid>
    <field name="syscheck.path">\.config/solana/id\.json$</field>
    <description>Crypto Honeypot: Access or modification detected in Solana id.json</description>
    <mitre>
      <id>T1552.004</id>
    </mitre>
  </rule>

  <!-- Rule for Electrum wallet access -->
  <rule id="100503" level="12">
    <if_sid>550,554,553</if_sid>
    <field name="syscheck.path">\.electrum/wallets/default_wallet$|Electrum/wallets/default_wallet$</field>
    <description>Crypto Honeypot: Access or modification detected in Electrum wallet</description>
    <mitre>
      <id>T1552.004</id>
    </mitre>
  </rule>

  <!-- Rule for Exodus wallet access -->
  <rule id="100504" level="12">
    <if_sid>550,554,553</if_sid>
    <field name="syscheck.path">Exodus/exodus\.wallet/seed\.secur$</field>
    <description>Crypto Honeypot: Access or modification detected in Exodus wallet dummy</description>
    <mitre>
      <id>T1552.004</id>
    </mitre>
  </rule>

  <!-- Rule for MetaMask vault access -->
  <rule id="100505" level="12">
    <if_sid>550,554,553</if_sid>
    <field name="syscheck.path">nkbihfbeogaeaoehlefnkodbefgpgknn/000003\.log$</field>
    <description>Crypto Honeypot: Access or modification detected in MetaMask vault file</description>
    <mitre>
      <id>T1552.004</id>
    </mitre>
  </rule>
</group>
